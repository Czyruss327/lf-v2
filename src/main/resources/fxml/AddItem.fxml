<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    AddItem.fxml
    Form for reporting an item.
    Open as a separate Stage when the + button is clicked.
-->
<BorderPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.AddItemController"
    stylesheets="@../css/styles.css"
    prefWidth="460" prefHeight="500"
    styleClass="detail-pane">

    <!-- Header -->
    <top>
        <HBox styleClass="detail-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="14" bottom="14" left="20" right="20" />
            </padding>
            <Label text="Report an Item" styleClass="detail-heading" HBox.hgrow="ALWAYS" />
            <Button text="✕" styleClass="close-btn" onAction="#onClose" />
        </HBox>
    </top>

    <!-- Form Fields -->
    <center>
        <VBox spacing="16" styleClass="detail-body">
            <padding>
                <Insets top="24" bottom="24" left="28" right="28" />
            </padding>

            <!-- Item Name -->
            <VBox spacing="6">
                <Label text="Item Name *" styleClass="form-label" />
                <TextField fx:id="nameField" promptText="e.g. Wallet, Phone, ID..."
                    styleClass="form-input" />
            </VBox>

            <!-- Status -->
            <VBox spacing="6">
                <Label text="Status *" styleClass="form-label" />
                <HBox spacing="16">
                    <RadioButton fx:id="lostRadio" text="Unclaimed" styleClass="form-radio">
                        <toggleGroup>
                            <ToggleGroup fx:id="statusGroup" />
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="foundRadio" text="Claimed" toggleGroup="$statusGroup"
                        styleClass="form-radio" />
                </HBox>
            </VBox>

            <!-- Color / Description -->
            <VBox spacing="6">
                <Label text="Color / Description" styleClass="form-label" />
                <TextField fx:id="colorField" promptText="e.g. Blue, Silver Acer..."
                    styleClass="form-input" />
            </VBox>

            <!-- Date -->
            <VBox spacing="6">
                <Label text="Date Reported *" styleClass="form-label" />
                <DatePicker fx:id="datePicker" styleClass="form-input" maxWidth="Infinity" />
            </VBox>

            <!-- Location -->
            <VBox spacing="6">
                <Label text="Location *" styleClass="form-label" />
                <ComboBox fx:id="locationCombo" styleClass="form-input" maxWidth="Infinity"
                    promptText="Select location...">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Court Bleacher" />
                            <String fx:value="Court" />
                            <String fx:value="Kubo" />
                            <String fx:value="Main Lobby" />
                            <String fx:value="Room 201" />
                            <String fx:value="Room 302" />
                            <String fx:value="Room 303" />
                            <String fx:value="Other" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <!-- Image Upload -->
            <VBox spacing="6">
                <Label text="Photo" styleClass="form-label" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="imagePathField" promptText="No file chosen"
                        styleClass="form-input" HBox.hgrow="ALWAYS" editable="false" />
                    <Button text="Browse" styleClass="btn-outline" onAction="#onBrowseImage" />
                </HBox>
            </VBox>

        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="12" bottom="20" left="28" right="28" />
            </padding>
            <Label fx:id="errorLabel" styleClass="error-label" HBox.hgrow="ALWAYS" />
            <Button text="SUBMIT" styleClass="btn-view" onAction="#onSubmit" />
            <Button text="CANCEL" styleClass="btn-cancel" onAction="#onClose" />
        </HBox>
    </bottom>

</BorderPane>