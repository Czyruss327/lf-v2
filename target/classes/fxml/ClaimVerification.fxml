<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.ClaimVerificationController"
    stylesheets="@../css/styles.css"
    prefWidth="960" prefHeight="700">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="10" bottom="10" left="20" right="20" />
            </padding>
            <ImageView fx:id="logoImage" fitWidth="36" fitHeight="36" preserveRatio="true" />
            <Label text="PUPSRC Lost and Found" styleClass="navbar-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addButton" text="+" styleClass="navbar-icon-btn" onAction="#onAddItem" />
            <Button fx:id="menuButton" text="..." styleClass="navbar-icon-btn" onAction="#onMenu" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="grid-scroll">
            <VBox alignment="TOP_CENTER" styleClass="main-content">
                <padding>
                    <Insets top="32" bottom="32" left="60" right="60" />
                </padding>

                <VBox styleClass="details-card" spacing="0">
                    <padding>
                        <Insets top="32" bottom="32" left="48" right="48" />
                    </padding>

                    <Label text="CLAIM VERIFICATION"
                        styleClass="page-title"
                        maxWidth="Infinity"
                        alignment="CENTER">
                        <VBox.margin>
                            <Insets bottom="28" />
                        </VBox.margin>
                    </Label>

                    <HBox spacing="48" alignment="TOP_LEFT">
                        <VBox spacing="16" prefWidth="380" minWidth="320">
                            <Label text="Claimant Information" styleClass="section-heading" />

                            <VBox spacing="5">
                                <HBox spacing="4">
                                    <Label text="Name" styleClass="form-label" />
                                    <Label text="*" styleClass="required-star" />
                                </HBox>
                                <TextField fx:id="claimNameField"
                                    promptText="Surname, First Name"
                                    styleClass="form-input" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Course and Section (If student)" styleClass="form-label" />
                                <TextField fx:id="courseSectionField"
                                    styleClass="form-input" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Email Address" styleClass="form-label" />
                                <TextField fx:id="emailField"
                                    styleClass="form-input" />
                            </VBox>

                            <VBox spacing="5">
                                <HBox spacing="4">
                                    <Label text="Contact Number" styleClass="form-label" />
                                    <Label text="(Required if more than 1 claimant)" styleClass="form-label" />
                                </HBox>
                                <TextField fx:id="contactField"
                                    promptText="09XX-XXX-XXXX"
                                    styleClass="form-input" />
                            </VBox>

                            <HBox spacing="14" alignment="TOP_LEFT">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="ID Presented" styleClass="form-label" />
                                    <TextField fx:id="studentIdField"
                                        styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="Upload ID" styleClass="form-label" />
                                    <Button text="Upload Images"
                                        styleClass="upload-btn"
                                        maxWidth="Infinity"
                                        onAction="#onUploadId" />
                                    <VBox fx:id="idListBox" spacing="6" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="16" HBox.hgrow="ALWAYS">
                            <Label text="Item Verification" styleClass="section-heading" />

                            <HBox spacing="14">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <HBox spacing="4">
                                        <Label text="Date Lost" styleClass="form-label" />
                                        <Label text="*" styleClass="required-star" />
                                    </HBox>
                                    <DatePicker fx:id="dateLostPicker"
                                        promptText="dd/mm/yyyy"
                                        styleClass="form-input"
                                        maxWidth="Infinity" />
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="Date Found" styleClass="form-label" />
                                    <DatePicker fx:id="dateFoundPicker"
                                        promptText="dd/mm/yyyy"
                                        styleClass="form-input"
                                        maxWidth="Infinity" />
                                </VBox>
                            </HBox>

                            <VBox spacing="5">
                                <Label text="Description" styleClass="form-label" />
                                <TextArea fx:id="descriptionArea"
                                    promptText="Describe the item (e.g., color, brand, unique marks)"
                                    styleClass="form-input"
                                    prefHeight="80"
                                    wrapText="true" />
                            </VBox>

                            <VBox spacing="5">
                                <HBox spacing="4">
                                    <Label text="Proof of Claim" styleClass="form-label" />
                                    <Label text="*" styleClass="required-star" />
                                </HBox>
                                <Button text="Upload Images"
                                    styleClass="upload-btn"
                                    maxWidth="Infinity"
                                    onAction="#onUploadProof" />
                                <VBox fx:id="proofListBox" spacing="6" />
                            </VBox>

                            <VBox spacing="8">
                                <HBox spacing="4">
                                    <Label text="Number of Claimants for this item" styleClass="form-label" />
                                    <Label text="*" styleClass="required-star" />
                                </HBox>
                                <CheckBox fx:id="singleClaimantCheck"
                                    text="One Claimant"
                                    selected="true"
                                    styleClass="form-check" />
                                <CheckBox fx:id="multipleClaimantsCheck"
                                    text="Two or more claimants"
                                    styleClass="form-check" />
                            </VBox>
                        </VBox>
                    </HBox>

                    <Label fx:id="errorLabel" styleClass="error-label"
                        wrapText="true" maxWidth="Infinity">
                        <VBox.margin>
                            <Insets top="8" />
                        </VBox.margin>
                    </Label>

                    <HBox spacing="16" alignment="CENTER">
                        <VBox.margin>
                            <Insets top="32" />
                        </VBox.margin>
                        <Button text="CANCEL" styleClass="btn-cancel" prefWidth="180"
                            onAction="#onCancel" />
                        <Button text="CONFIRM CLAIM" styleClass="btn-view" prefWidth="180"
                            onAction="#onConfirmClaim" />
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
