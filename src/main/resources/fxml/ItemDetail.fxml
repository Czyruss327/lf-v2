<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<!--
    ItemDetail.fxml
    Modal-style detail view shown when user clicks VIEW DETAILS.
    Load with FXMLLoader and display inside a Stage (UTILITY style).
-->
<BorderPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.ItemDetailController"
    stylesheets="@../css/styles.css"
    prefWidth="480" prefHeight="420"
    styleClass="detail-pane">

    <!-- Header -->
    <top>
        <HBox styleClass="detail-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="14" bottom="14" left="20" right="20" />
            </padding>
            <Label fx:id="detailTitle" styleClass="detail-heading" HBox.hgrow="ALWAYS" />
            <Button text="✕" styleClass="close-btn" onAction="#onClose" />
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <HBox spacing="20" styleClass="detail-body">
            <padding>
                <Insets top="20" bottom="20" left="24" right="24" />
            </padding>

            <!-- Photo -->
            <VBox alignment="TOP_CENTER" spacing="10" minWidth="180">
                <StackPane styleClass="detail-img-wrap" prefWidth="180" prefHeight="180">
                    <ImageView fx:id="detailImage"
                        fitWidth="180" fitHeight="180"
                        preserveRatio="false" />
                    <Label fx:id="detailStatusBadge" styleClass="badge"
                        StackPane.alignment="TOP_RIGHT">
                        <StackPane.margin>
                            <Insets top="8" right="8" />
                        </StackPane.margin>
                    </Label>
                </StackPane>
            </VBox>

            <!-- Info -->
            <VBox spacing="14" HBox.hgrow="ALWAYS">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Item Name" styleClass="detail-label" minWidth="100" />
                    <Label fx:id="detailName" styleClass="detail-value" />
                </HBox>
                <Separator />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Color / Type" styleClass="detail-label" minWidth="100" />
                    <Label fx:id="detailColor" styleClass="detail-value" />
                </HBox>
                <Separator />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Date Found" styleClass="detail-label" minWidth="100" />
                    <Label fx:id="detailDate" styleClass="detail-value" />
                </HBox>
                <Separator />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Location Found" styleClass="detail-label" minWidth="100" />
                    <Label fx:id="detailLocation" styleClass="detail-value" />
                </HBox>
                <Separator />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Status" styleClass="detail-label" minWidth="100" />
                    <Label fx:id="detailStatus" styleClass="detail-value" />
                </HBox>

            </VBox>
        </HBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="12" bottom="16" left="24" right="24" />
            </padding>
            <Button text="CLAIM ITEM" styleClass="btn-view" onAction="#onClaimItem" />
            <Button text="CLOSE" styleClass="btn-cancel" onAction="#onClose" />
        </HBox>
    </bottom>

</BorderPane>